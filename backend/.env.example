# Copy to `.env` for local (non-Docker) development.
# When running via docker-compose, these are provided by the compose file.

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Database --- (use asyncpg driver; host is `postgres` inside compose)
DATABASE_URL=postgresql+asyncpg://lf:lf_pass@localhost:5432/lostfound

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ---
JWT_SECRET_KEY=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_EXPIRE_MINUTES=30
EMAIL_VERIFY_EXPIRE_HOURS=48

# --- Email / front-end links ---
EMAIL_BACKEND=console
FRONTEND_URL=http://localhost:3000
# MVP default: registration works immediately, no verified-email gating.
REQUIRE_EMAIL_VERIFICATION=false

# --- AI (used from M4) ---
OPENAI_API_KEY=

# --- Storage ---
STORAGE_PROVIDER=local
MEDIA_ROOT=./media
